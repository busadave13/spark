{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "{projectName}: Build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/{projectName}/{projectName}/{projectName}.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    },
    {
      "label": "{projectName}: Run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/{projectName}/{projectName}/{projectName}.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/{projectName}/{projectName}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    },
    {
      "label": "{projectName}.UnitTests: Run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/{projectName}/{projectName}.UnitTests/{projectName}.UnitTests.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": false
      }
    }
  ]
}
