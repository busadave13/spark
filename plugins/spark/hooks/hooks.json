{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "& $HOME/.copilot/hooks/scripts/session-start.ps1",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "powershell": "& $HOME/.copilot/hooks/scripts/pre-tool.ps1",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "powershell": "& $HOME/.copilot/hooks/scripts/post-tool.ps1",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "& $HOME/.copilot/hooks/scripts/session-end.ps1",
        "timeoutSec": 30
      }
    ]
  }
}